# JobBot — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains your credentials

# ── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Handshake (optional — for college students) ────────────────────────────
HANDSHAKE_EMAIL=your@university.edu
HANDSHAKE_PASSWORD=your_handshake_password

# ── OpenAI (required for AI cover letter generation) ──────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── Spend limit — hard cap on daily OpenAI usage ──────────────────────────
DAILY_SPEND_LIMIT=0.50

# ── Email digest (optional) ────────────────────────────────────────────────
# Set DIGEST_EMAIL to receive a daily summary email
DIGEST_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_PORT=5555
